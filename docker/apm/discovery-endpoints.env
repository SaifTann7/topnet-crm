# TOPNET CRM — APM discovery endpoint URLs
# Source from shell:  set -a && source docker/apm/discovery-endpoints.env && set +a

TOPNET_APM_APPLICATION_NAME=TOPNET CRM
TOPNET_APM_VERSION=1.0.0-SNAPSHOT

# Host access (via Nginx reverse proxy)
TOPNET_APM_BASE_URL=http://localhost
TOPNET_APM_HEALTH_URL=${TOPNET_APM_BASE_URL}/actuator/health
TOPNET_APM_INFO_URL=${TOPNET_APM_BASE_URL}/actuator/info
TOPNET_APM_METRICS_URL=${TOPNET_APM_BASE_URL}/actuator/metrics
TOPNET_APM_APPLICATION_INFO_URL=${TOPNET_APM_BASE_URL}/application/info
TOPNET_APM_OPENAPI_URL=${TOPNET_APM_BASE_URL}/v3/api-docs

# Direct backend access (bypass Nginx)
TOPNET_APM_BACKEND_URL=http://localhost:8080
TOPNET_APM_BACKEND_HEALTH_URL=${TOPNET_APM_BACKEND_URL}/actuator/health

# Docker internal (container-to-container)
TOPNET_APM_DOCKER_BACKEND_URL=http://backend:8080
TOPNET_APM_DOCKER_HEALTH_URL=${TOPNET_APM_DOCKER_BACKEND_URL}/actuator/health

DOCKER_READY=true
