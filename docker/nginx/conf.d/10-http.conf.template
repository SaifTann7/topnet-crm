# =============================================================================
# TOPNET CRM — HTTP server (port 80)
# Used when SSL is disabled or to redirect to HTTPS
# =============================================================================

server {
    listen 80;
    listen [::]:80;
    server_name crm.topnet.local;

    include /etc/nginx/snippets/security-headers.conf;

    include /etc/nginx/conf.d/locations.inc;
}
