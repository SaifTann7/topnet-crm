# HTTP-only mode — serves the full application on port 80
# Used when NGINX_SSL_ENABLED=false

server {
    listen 443 ssl;
    server_name crm.topnet.local;

    ssl_certificate     /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;

    location / {
        proxy_pass http://frontend:80;
    }

    location /api {
        proxy_pass http://backend:8080;
    }
}


