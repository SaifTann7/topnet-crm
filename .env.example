# =============================================================================
# TOPNET CRM — Production Docker Environment
# Copy to .env and adjust before running: docker compose up -d
# =============================================================================

# --- Application ---
APP_NAME=topnet-crm
APP_VERSION=1.0.0-SNAPSHOT
COMPOSE_PROJECT_NAME=topnet-crm

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=topnet_crm
POSTGRES_USER=topnet
POSTGRES_PASSWORD=topnet123

# --- Spring Boot Backend ---
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=docker
JWT_SECRET=topnet-crm-docker-secret-key-change-in-production-min-256-bits!!
JWT_EXPIRATION_MS=86400000
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# --- Angular Frontend (direct access, optional) ---
FRONTEND_PORT=4200

# --- Nginx Reverse Proxy ---
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_HOST=localhost
NGINX_SSL_ENABLED=true
# TLS certs: docker/nginx/ssl/fullchain.pem + privkey.pem
# Local dev HTTPS: cd docker/nginx/ssl && ./generate-self-signed.sh

# --- APM Discovery (external monitoring platforms) ---
TOPNET_APM_BASE_URL=http://localhost
TOPNET_APM_APPLICATION_NAME=TOPNET CRM
TOPNET_APM_VERSION=1.0.0-SNAPSHOT
DOCKER_READY=true
# BACKEND_MEMORY_LIMIT=1g
# POSTGRES_MEMORY_LIMIT=512m
